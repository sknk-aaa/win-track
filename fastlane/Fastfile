default_platform(:ios)

WIDGET_TARGET = ENV["WIDGET_TARGET"] || "WinRateWidget"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["ASC_API_KEY_PATH"],
      in_house: false
    )
  end

  def app_id
    ENV["APP_IDENTIFIER"]
  end

  def widget_id
    ENV["WIDGET_IDENTIFIER"]
  end

  def project_root
    File.expand_path("..", __dir__)
  end

  def detect_workspace
    Dir[File.join(project_root, "ios", "*.xcworkspace")].first or
      UI.user_error!("ios/*.xcworkspace が見つかりません。先に expo prebuild + pod install を実行")
  end

  def profile_name(identifier)
    ENV["sigh_#{identifier}_appstore_profile-name"] || "match AppStore #{identifier}"
  end

  desc "証明書/プロファイルを作成しmatchリポへ保存（初回1回だけ・アプリ＋Widget）"
  lane :certs do
    match(type: "appstore", readonly: false, app_identifier: [app_id, widget_id], api_key: asc_api_key)
  end

  desc "証明書取得→署名→IPAビルド（アプリ＋Widget）"
  lane :build do
    workspace = detect_workspace
    scheme = File.basename(workspace, ".xcworkspace")
    project = File.join(project_root, "ios", "#{scheme}.xcodeproj")
    build_no = ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s
    app_profile = profile_name(app_id)
    widget_profile = profile_name(widget_id)

    match(type: "appstore", readonly: true, app_identifier: [app_id, widget_id], api_key: asc_api_key)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: project,
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: app_profile,
      targets: [scheme]
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: project,
      team_id: ENV["APPLE_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: widget_profile,
      targets: [WIDGET_TARGET]
    )

    [
      File.join(project_root, "ios", scheme, "Info.plist"),
      File.join(project_root, "targets", WIDGET_TARGET, "Info.plist")
    ].uniq.each do |plist|
      set_info_plist_value(path: plist, key: "CFBundleVersion", value: build_no) if File.exist?(plist)
    end

    gym(
      workspace: workspace,
      scheme: scheme,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "app.ipa",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          app_id => app_profile,
          widget_id => widget_profile
        }
      }
    )
  end

  desc "ビルドしてTestFlightへ配信"
  lane :beta do
    build
    pilot(
      api_key: asc_api_key,
      ipa: "build/app.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end
end
